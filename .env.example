# Required for video uploads (auto-set when the Vercel Blob store is connected;
# locally: `vercel env pull .env.local`)
BLOB_READ_WRITE_TOKEN=

# Optional — enables LIVE web-searched training feed instead of the curated seed.
# Provide either (or both; Tavily wins if both set):
TAVILY_API_KEY=
YOUTUBE_API_KEY=
